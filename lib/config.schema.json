{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Instructions & Prompts Configuration",
  "description": "Schema for config.json - validates tool output, languages, frameworks, and structures for Claude Code",
  "type": "object",
  "required": ["version", "tool", "languages"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "tool": {
      "type": "object",
      "description": "Claude Code output configuration",
      "required": ["name", "outputDir", "outputFile", "fileExtension"],
      "properties": {
        "name": { "type": "string" },
        "outputDir": { "type": "string", "description": "Directory for modular rules (e.g., .claude/rules)" },
        "outputFile": { "type": "string", "description": "Project-level instructions file (e.g., CLAUDE.md)" },
        "outputFileSource": { "type": "string", "description": "Source rule file for outputFile (without extension)" },
        "fileExtension": { "type": "string", "description": "File extension for rule files (e.g., .md)" }
      },
      "additionalProperties": false
    },
    "languages": {
      "type": "object",
      "description": "Programming languages and their frameworks",
      "patternProperties": {
        "^[a-z-]+$": {
          "type": "object",
          "required": ["name", "globs", "alwaysApply", "description", "files"],
          "properties": {
            "name": { "type": "string" },
            "globs": { "type": "string" },
            "alwaysApply": { "type": "boolean" },
            "description": { "type": "string" },
            "files": {
              "type": "array",
              "items": { "type": "string" }
            },
            "documentation": {
              "type": "object",
              "description": "Optional documentation standards (typically under 'general')",
              "patternProperties": {
                "^[a-z-]+$": {
                  "type": "object",
                  "required": ["name", "file", "description"],
                  "properties": {
                    "name": { "type": "string" },
                    "file": { "type": "string" },
                    "description": { "type": "string" },
                    "recommended": { "type": "boolean" },
                    "applicableTo": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "optionalRules": {
              "type": "object",
              "description": "Optional rule files gated by setup toggles",
              "patternProperties": {
                "^[a-z-]+$": {
                  "type": "object",
                  "required": ["name", "file", "description", "toggle"],
                  "properties": {
                    "name": { "type": "string" },
                    "file": { "type": "string" },
                    "description": { "type": "string" },
                    "toggle": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "processes": {
              "type": "object",
              "description": "Optional language process guides (permanent and on-demand)",
              "patternProperties": {
                "^[a-z-]+$": {
                  "type": "object",
                  "required": ["name", "file", "description", "type", "loadIntoAI"],
                  "properties": {
                    "name": { "type": "string" },
                    "file": { "type": "string" },
                    "description": { "type": "string" },
                    "type": { "type": "string", "enum": ["ondemand", "permanent"] },
                    "loadIntoAI": { "type": "boolean" }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "frameworks": {
              "type": "object",
              "patternProperties": {
                "^[a-z-]+$": {
                  "type": "object",
                  "required": ["name", "file"],
                  "properties": {
                    "name": { "type": "string" },
                    "file": { "type": "string" },
                    "category": { "type": "string" },
                    "description": { "type": "string" },
                    "recommended": { "type": "boolean" },
                    "requires": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Array of framework keys this framework depends on"
                    },
                    "structures": {
                      "type": "object",
                      "patternProperties": {
                        "^[a-z-]+$": {
                          "type": "object",
                          "required": ["name", "file", "description"],
                          "properties": {
                            "name": { "type": "string" },
                            "file": { "type": "string" },
                            "description": { "type": "string" },
                            "recommended": { "type": "boolean" }
                          },
                          "additionalProperties": false
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
